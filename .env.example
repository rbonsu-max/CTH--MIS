# ───────────────────────────────────────────────────────
# CTHMIS Environment Configuration
# Copy this to .env and fill in the values
# ───────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3009

# Security — CHANGE THIS before deploying!
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Database — absolute path recommended for production
DB_PATH=/www/wwwroot/cthmis/sims.db

# Application URL — used for CORS in production
APP_URL=https://yourdomain.com

# Optional: Gemini AI API Key (if using AI features)
# GEMINI_API_KEY=your-gemini-api-key
